# =============================================================
# Plan N'Go — Variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves
# NUNCA commite o arquivo .env no git
# =============================================================

# Django
SECRET_KEY=gere-uma-chave-em-https://djecrety.ir
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (vazio = SQLite em desenvolvimento)
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/plango

# E-mail (dev: imprime no terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@plango.app

# CORS
FRONTEND_URL=http://localhost:5173

# =============================================================
# IA — Extração de dados de destinos
# Obtenha em: aistudio.google.com/apikey
# =============================================================
GEMINI_API_KEY=
AI_BACKEND=gemini  # gemini (gratuito) | anthropic (pago, para produção)

# Anthropic Claude (opcional, para produção)
# Obtenha em: console.anthropic.com
ANTHROPIC_API_KEY=

# =============================================================
# Geocoding — Autocomplete de destinos
# =============================================================
GEOCODING_BACKEND=nominatim  # nominatim (gratuito) | google (requer chave)

# Google Places API (opcional, só se GEOCODING_BACKEND=google)
# Obtenha em: console.cloud.google.com
GOOGLE_PLACES_API_KEY=

# =============================================================
# Imagens — Busca automática de fotos dos destinos
# Obtenha em: unsplash.com/developers
# =============================================================
UNSPLASH_ACCESS_KEY=

# =============================================================
# Google Custom Search (alternativa futura ao Unsplash)
# Ver documentação em: docs/image_search.md
# Requer billing ativo no Google Cloud
# =============================================================
# GOOGLE_CUSTOM_SEARCH_KEY=
# GOOGLE_CUSTOM_SEARCH_CX=
